generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  email          String    @unique
  password       String
  role           String    @default("user")
  createdAt      DateTime  @default(now())

  @@map("users")
}

model Visitor {
  id         Int      @id @default(autoincrement())
  sessionId  String
  ip         String
  page       String
  referrer   String?
  userAgent  String?
  device     String?
  browser    String?
  os         String?
  createdAt  DateTime @default(now())

  @@map("visitors")
}

model PageView {
  id    Int      @id @default(autoincrement())
  page  String
  date  DateTime @db.Date
  views Int      @default(1)

  @@unique([page, date])
  @@map("page_views")
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contacts")
}

// ══════════════════════════════════════════
//  TAMIM TOASTMASTERS CLUB
// ══════════════════════════════════════════

enum ClubSpeechCategory {
  PREPARED
  EVALUATION
  IMPROMPTU
}

model ClubSettings {
  id             Int    @id @default(1)
  clubName       String @default("نادي تميم توستماسترز")
  description    String @default("أين تصنع القيادة ممارستها اليومية")
  logoUrl        String @default("")
  logoAltUrl     String @default("")
  aboutTitle     String @default("ما هي التوستماسترز؟")
  aboutText      String @default("منظمة عالمية غير ربحية تساعد الأفراد على تطوير مهارات التواصل والخطابة والقيادة. يوفر نادي تميم لك بيئة إيجابية ومحفزة لتصبح خطيباً وقائداً متمكناً.")
  colorPrimary   String @default("#1c2b39")
  colorSecondary String @default("#7a222c")
  colorAccent    String @default("#00a3e0")

  @@map("club_settings")
}

model ClubLink {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("club_links")
}

model ClubSpeaker {
  id        Int                @id @default(autoincrement())
  category  ClubSpeechCategory
  name      String
  createdAt DateTime           @default(now())

  @@map("club_speakers")
}

model ClubVote {
  id        Int                @id @default(autoincrement())
  category  ClubSpeechCategory
  candidate String
  createdAt DateTime           @default(now())

  @@map("club_votes")
}

