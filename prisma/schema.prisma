generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── المستخدمون ───
model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(150)
  password       String    @db.VarChar(255)
  name           String    @db.VarChar(100)
  role           String    @default("user") @db.VarChar(20)
  emailVerified  Boolean   @default(false)
  verifyToken    String?   @db.VarChar(255)
  verifyExpires  DateTime?
  resetToken     String?   @db.VarChar(255)
  resetExpires   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("users")
}

// ─── تتبع الزوار ───
model Visitor {
  id        Int      @id @default(autoincrement())
  sessionId String   @db.VarChar(64)
  ip        String   @db.VarChar(64)
  page      String   @db.VarChar(255)
  referrer  String?  @db.VarChar(500)
  userAgent String?  @db.Text
  device    String   @default("unknown") @db.VarChar(20)
  browser   String   @default("unknown") @db.VarChar(50)
  os        String   @default("unknown") @db.VarChar(50)
  createdAt DateTime @default(now())

  @@index([page])
  @@index([createdAt])
  @@index([sessionId])
  @@map("visitors")
}

// ─── إحصاء الصفحات ───
model PageView {
  id        Int      @id @default(autoincrement())
  page      String   @db.VarChar(255)
  views     Int      @default(1)
  date      DateTime @db.Date
  updatedAt DateTime @updatedAt

  @@unique([page, date])
  @@index([date])
  @@map("page_views")
}

// ─── سجل QR Code ───
model QrHistory {
  id        Int      @id @default(autoincrement())
  type      String   @db.VarChar(20)
  value     String   @db.Text
  format    String   @db.VarChar(10)
  corner    String?  @db.VarChar(10)
  hasLogo   Boolean  @default(false)
  bulkCount Int?
  ip        String?  @db.VarChar(64)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("qr_history")
}

// ─── سجل الشهادات ───
model CertHistory {
  id            Int      @id @default(autoincrement())
  recipientName String   @db.VarChar(255)
  courseName    String   @db.VarChar(255)
  centerName    String?  @db.VarChar(255)
  template      String   @db.VarChar(20)
  ip            String?  @db.VarChar(64)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@map("cert_history")
}

// ─── سجل التقارير ───
model ReportHistory {
  id          Int      @id @default(autoincrement())
  reportTitle String   @db.VarChar(255)
  reportType  String   @db.VarChar(30)
  companyName String?  @db.VarChar(255)
  rowCount    Int      @default(0)
  ip          String?  @db.VarChar(64)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("report_history")
}

// ─── رسائل التواصل ───
model Contact {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(150)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@map("contacts")
}
