generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  email          String    @unique
  password       String
  role           String    @default("user")
  emailVerified  Boolean   @default(false)
  verifyToken    String?
  verifyExpires  DateTime?
  resetToken     String?
  resetExpires   DateTime?
  createdAt      DateTime  @default(now())

  @@map("users")
}

model Visitor {
  id         Int      @id @default(autoincrement())
  sessionId  String
  ip         String
  page       String
  referrer   String?
  userAgent  String?
  device     String?
  browser    String?
  os         String?
  createdAt  DateTime @default(now())

  @@map("visitors")
}

model PageView {
  id    Int      @id @default(autoincrement())
  page  String
  date  DateTime @db.Date
  views Int      @default(1)

  @@unique([page, date])
  @@map("page_views")
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contacts")
}

model QrHistory {
  id         Int      @id @default(autoincrement())
  type       String
  value      String
  format     String
  corner     String
  hasLogo    Boolean  @default(false)
  bulkCount  Int?
  ip         String
  createdAt  DateTime @default(now())

  @@map("qr_history")
}

model CertHistory {
  id            Int      @id @default(autoincrement())
  recipientName String
  courseName    String
  centerName    String?
  template      String
  ip            String
  createdAt     DateTime @default(now())

  @@map("cert_history")
}

model ReportHistory {
  id          Int      @id @default(autoincrement())
  reportTitle String
  reportType  String
  companyName String?
  rowCount    Int      @default(0)
  ip          String
  createdAt   DateTime @default(now())

  @@map("report_history")
}

// ══════════════════════════════════════════
//  ATTENDANCE SAAS — multi-tenant
// ══════════════════════════════════════════

enum AttPlan {
  TRIAL
  BASIC
  PRO
}

enum AttRole {
  ADMIN
  EMPLOYEE
}

enum AttStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
}

model AttOrganization {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique        // company-slug → subdomain later
  plan        AttPlan    @default(TRIAL)
  planExpires DateTime?
  adminSecret String                    // hashed password for org admin login
  email                String?
  phone                String?
  address              String?
  attendanceWindowMins Int        @default(10)
  lateToleranceMins    Int        @default(0)
  displayKey           String     @unique @default(cuid())  // secret key for display screen URL
  createdAt            DateTime   @default(now())

  employees    AttEmployee[]
  shifts       AttShift[]
  attendance   AttRecord[]
  qrSessions   AttQrSession[]
  monthArchives AttMonthArchive[]

  @@map("att_organizations")
}

model AttEmployee {
  id                  Int             @id @default(autoincrement())
  organizationId      Int
  org                 AttOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String
  email               String
  password            String
  role                AttRole         @default(EMPLOYEE)
  shiftId             Int?
  shift               AttShift?       @relation(fields: [shiftId], references: [id])
  active              Boolean         @default(true)
  // WebAuthn device binding
  credentialId        String?         // base64url — bound on first login
  credentialPublicKey Bytes?          // public key stored as bytes
  credentialCounter   Int             @default(0)
  deviceBound         Boolean         @default(false)
  challenge           String?         // temporary WebAuthn challenge
  salary              Decimal?        // monthly salary
  overtimeRate        Decimal?        // overtime hourly rate (if null, auto-calculated from salary)
  createdAt           DateTime        @default(now())

  attendance    AttRecord[]
  monthArchives AttMonthArchive[]

  @@unique([email, organizationId])
  @@map("att_employees")
}

model AttShift {
  id             Int             @id @default(autoincrement())
  organizationId Int
  org            AttOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String          // "Morning" / "Evening"
  startTime      String          // "09:00"
  endTime        String          // "17:00"
  workDays       String[]        // ["MON","TUE","WED","THU","FRI"]
  createdAt      DateTime        @default(now())

  employees      AttEmployee[]

  @@map("att_shifts")
}

model AttRecord {
  id              Int             @id @default(autoincrement())
  organizationId  Int
  org             AttOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId      Int
  employee        AttEmployee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime        @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  status          AttStatus       @default(PRESENT)
  lateMinutes     Int             @default(0)
  overtimeMinutes Int             @default(0)
  notes           String?
  editedBy        String?         // admin override
  excuseType      String?         // SICK | VACATION | PERSONAL | OTHER
  excuseFile      String?         // base64 data URL of uploaded document
  excuseNote      String?         // employee's text note
  excuseApproved  Boolean?        // null=pending, true=approved, false=rejected
  createdAt       DateTime        @default(now())

  @@unique([employeeId, date])
  @@map("att_records")
}

model AttMonthArchive {
  id              Int             @id @default(autoincrement())
  organizationId  Int
  org             AttOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId      Int
  employee        AttEmployee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year            Int
  month           Int             // 1–12
  presentDays     Int             @default(0)
  lateDays        Int             @default(0)
  absentDays      Int             @default(0)
  excusedDays     Int             @default(0)  // absences with approved excuse
  lateMinutes     Int             @default(0)
  overtimeMinutes Int             @default(0)
  salarySnapshot  Decimal?        // salary at time of archive
  overtimePay     Decimal?
  totalDue        Decimal?
  createdAt       DateTime        @default(now())

  @@unique([employeeId, year, month])
  @@map("att_month_archives")
}

model AttQrSession {
  id              Int             @id @default(autoincrement())
  organizationId  Int
  org             AttOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secret          String          // TOTP secret for this org
  active          Boolean         @default(true)
  updatedAt       DateTime        @updatedAt
  displayDeviceId String?         // UUID of the device currently showing the display screen
  displayLastSeen DateTime?       // last heartbeat from that device

  @@unique([organizationId])
  @@map("att_qr_sessions")
}
